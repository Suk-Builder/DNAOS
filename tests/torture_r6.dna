# ============================================================================
# TORTURE ROUND 6 — 第41-50轮：性能与深层循环
# ============================================================================
NUM st[40] 0
NUM st[41] 1
NUM st[42] 2

# 41. 1000次加法循环
NUM st[0] 0
NUM st[1] 1000
LABEL @loop41
ADD st[0] st[41]
CMP st[0] st[1]
JL @loop41
PRINT st[0]

# 42. 嵌套循环（100*100=10000次）
NUM st[0] 0
NUM st[1] 100
NUM st[2] 100
NUM st[3] 0
LABEL @outer42
NUM st[4] 0
LABEL @inner42
ADD st[0] st[41]
ADD st[4] st[41]
CMP st[4] st[1]
JL @inner42
ADD st[3] st[41]
CMP st[3] st[2]
JL @outer42
PRINT st[0]

# 43. 斐波那契数列前20项和
NUM st[0] 0
NUM st[1] 1
NUM st[2] 0
NUM st[3] 20
NUM st[4] 0
LABEL @fib_loop
ADD st[2] st[0]
NUM st[5] 0
ADD st[5] st[0]
ADD st[0] st[1]
NUM st[1] 0
ADD st[1] st[5]
ADD st[4] st[41]
CMP st[4] st[3]
JL @fib_loop
PRINT st[2]

# 44. 阶乘累加 1!+2!+...+10!
NUM st[0] 0
NUM st[1] 1
NUM st[2] 1
LABEL @fact_loop
NUM st[3] 0
ADD st[3] st[1]
FACT st[3] st[3]
ADD st[0] st[3]
ADD st[1] st[41]
ADD st[2] st[41]
CMP st[2] st[42]
JLE @fact_loop
PRINT st[0]

# 45. 平方和 1^2+2^2+...+100^2 = 338350
NUM st[0] 0
NUM st[1] 1
NUM st[2] 100
LABEL @sq_loop
NUM st[3] 0
ADD st[3] st[1]
MUL st[3] st[1]
ADD st[0] st[3]
ADD st[1] st[41]
CMP st[1] st[2]
JLE @sq_loop
PRINT st[0]

# 46. 2的幂次和 2^0+2^1+...+2^10 = 2047
NUM st[0] 0
NUM st[1] 1
NUM st[2] 10
NUM st[3] 0
LABEL @pow_loop
NUM st[4] 1
POW st[4] st[3]
ADD st[0] st[4]
ADD st[3] st[41]
CMP st[3] st[2]
JLE @pow_loop
PRINT st[0]

# 47. 埃拉托斯特尼筛法（前30个数的素数个数）
NUM st[46] 30
CALL @sieve
PRINT st[49]

# 48. GCD 连算
NUM st[0] 720
NUM st[1] 120
GCD st[0] st[1]
NUM st[1] 48
GCD st[0] st[1]
NUM st[1] 24
GCD st[0] st[1]
PRINT st[0]

# 49. 向量点积 [1..10]·[1..10] = 385
NUM st[50] 1
NUM st[51] 2
NUM st[52] 3
NUM st[53] 4
NUM st[54] 5
NUM st[55] 6
NUM st[56] 7
NUM st[57] 8
NUM st[58] 9
NUM st[59] 10
NUM st[60] 1
NUM st[61] 2
NUM st[62] 3
NUM st[63] 4
DOT st[49] st[50] st[60] 4
PRINT st[49]

# 50. 递砖机标记
NUM st[60] 7777777
PRINT st[60]
HALT

LABEL @sieve
NUM st[47] 0
NUM st[43] 1
NUM st[44] 0
LABEL @sv_loop
ADD st[44] st[43]
CMP st[44] st[46]
JG @sv_done
NUM st[48] 0
ADD st[48] st[44]
NUM st[45] 0
ADD st[45] st[44]
SUB st[45] st[43]
LABEL @sv_inner
CMP st[45] st[43]
JL @sv_prime
NUM st[50] 0
ADD st[50] st[44]
DIV st[50] st[45]
MUL st[50] st[45]
CMP st[50] st[48]
JE @sv_next
SUB st[45] st[43]
JMP @sv_inner
LABEL @sv_prime
ADD st[47] st[43]
LABEL @sv_next
ADD st[44] st[43]
JMP @sv_loop
LABEL @sv_done
NUM st[49] 0
ADD st[49] st[47]
RET
