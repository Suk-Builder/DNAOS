; test_nsm.dna — NSM神经状态机测试
; 验证忆阻器交叉阵列的核心功能
; 
; 测试内容：
;   1. DAC输出电压到交叉阵列
;   2. SET增强电导（LTP）
;   3. RST减弱电导（LTD）
;   4. VMM向量矩阵乘法
;   5. READ读取电导值
;   6. STDP脉冲时间依赖可塑性
;   7. CHEM化学递质调制

; === 测试1: DAC输出 + SET + READ ===
NUM st[60] 5     ; row = 5
NUM st[61] 10    ; col = 10
NUM st[62] 100   ; DAC输出100mV
NUM st[63] 50    ; pulse width = 50ns

; DAC输出电压到(row, col)
DAC st[60] st[61] st[62]

; SET脉冲增强电导(LTP)
SET st[60] st[61] st[63]

; 读取电导值到st[0]
READ st[0] st[60] st[61]
PRINT st[0]

; === 测试2: RST减弱电导(LTD) ===
RST st[60] st[61] st[63]
READ st[0] st[60] st[61]
PRINT st[0]

; === 测试3: STDP学习 ===
; pre在post之前放电 → LTP
NUM st[50] 0     ; pre_time = 0ms
NUM st[51] 15    ; post_time = 15ms (Δt=15ms>0 → LTP)

; 先SET增强一点电导
SET st[60] st[61] st[63]
READ st[0] st[60] st[61]
PRINT st[0]

; 【STDP: pre=row5, post=col10】
STDP st[60] st[61] st[50] st[51]
READ st[0] st[60] st[61]
PRINT st[0]

; === 测试4: CHEM化学调制(多巴胺增强) ===
NUM st[40] 0     ; chem_type = 多巴胺
NUM st[41] 500   ; intensity = 0.5

CHEM st[40] st[41]
READ st[0] st[60] st[61]
PRINT st[0]

; === 测试5: VMM向量矩阵乘法 ===
; 加载多个输入电压
NUM st[20] 0
NUM st[21] 0
DAC st[20] st[21] 50     ; V[0] = 50mV

NUM st[22] 1
NUM st[23] 0
DAC st[22] st[23] 100    ; V[1] = 100mV

; 对几个位置做SET增强电导
NUM st[24] 100
SET st[20] st[21] st[24]  ; G[0][0] SET
SET st[22] st[23] st[24]  ; G[1][0] SET

; 执行VMM
VMM

; VMM结果在I数组中，读取I[0]
READ st[0] st[20] st[21]
PRINT st[0]

; === 最终统计 ===
NUM st[99] 7777
PRINT st[99]

HALT
