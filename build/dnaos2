#!/bin/bash
# DNAOS v2.0 Launcher Script (system-like experience)
# This wraps the compiled binary with a boot sequence

DNAOS_DIR="${HOME}/.dnaos"
BINARY="${DNAOS_DIR}/dnaos2"

# If not installed, run from current directory
if [ ! -f "$BINARY" ]; then
    BINARY="./dnaos2"
fi

if [ ! -f "$BINARY" ]; then
    echo "DNAOS not found. Run ./install.sh first."
    exit 1
fi

# Boot sequence
case "$1" in
    --help|-h)
        echo "DNAOS v2.0 Genesis -- Charter Operating System"
        echo ""
        echo "Usage: dnaos [OPTION]"
        echo ""
        echo "Options:"
        echo "  (none)     Boot DNAOS with full charter display"
        echo "  --quick    Quick boot (skip charter preamble)"
        echo "  --shell    Interactive DNAOS shell"
        echo "  --test     Run self-test suite"
        echo "  --version  Show version"
        echo "  --help     Show this help"
        echo ""
        echo "Examples:"
        echo "  dnaos              # Full boot with charter"
        echo "  dnaos --shell      # Interactive mode"
        echo "  dnaos --test       # Verify all systems"
        ;;
    --version|-v)
        echo "DNAOS v2.0.0-Charter (Genesis)"
        ;;
    --quick)
        # Skip charter, just run math demo
        exec "$BINARY" --quick 2>/dev/null || echo "Quick mode not yet implemented in binary"
        ;;
    --shell)
        echo "========================================"
        echo "  DNAOS v2.0 Interactive Shell"
        echo "  Type 'help' for commands"
        echo "========================================"
        echo ""
        while true; do
            printf "dnaos> "
            read -r cmd
            case "$cmd" in
                quit|exit) break ;;
                help)
                    echo "Commands:"
                    echo "  lucas <p>    - Test Mersenne prime"
                    echo "  pi <n>       - Count primes up to n"
                    echo "  fib <n>      - Fibonacci"
                    echo "  fact <n>     - Factorial"
                    echo "  charter      - Display UN Charter"
                    echo "  esv          - Read environmental signals"
                    echo "  atp          - Check energy budget"
                    echo "  clear)       - Clear screen"
                    echo "  quit)        - Exit shell"
                    ;;
                charter)
                    exec "$BINARY" 2>/dev/null | head -40
                    ;;
                lucas*)
                    p=$(echo "$cmd" | awk '{print $2}')
                    [ -z "$p" ] && p=127
                    echo "[DNAOS] Lucas-Lehmer M_$p..."
                    exec "$BINARY" 2>/dev/null | grep -A20 "MATH.*Mersenne"
                    ;;
                clear)
                    clear
                    ;;
                "")
                    ;;
                *)
                    echo "Unknown command: $cmd"
                    ;;
            esac
        done
        ;;
    *)
        # Full boot
        exec "$BINARY"
        ;;
esac
