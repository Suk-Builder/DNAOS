# === DNAsm v3.3 HAL Test ===
# Test SLEEP and REAGENT instructions

# Setup: Hg2+ reagent quantity = 0.1 mg (stored as 100 for 0.1mg precision)
NUM st[0] 100

# Setup: reagent type = 0 (Hg2+ ion)
NUM st[1] 0

# Record consumption of 0.1mg Hg2+
REAGENT st[0] st[1]

# Sleep 100ms (simulating wet lab delay)
SLEEP 100

# Verify st[0] still holds the value
PRINT st[0]

# Test SLEEP with tube reference
NUM st[2] 50
SLEEP st[2]

# Test REAGENT with immediate type
NUM st[3] 250
REAGENT st[3] 1

# Add two numbers to verify math still works
NUM st[4] 42
NUM st[5] 58
ADD st[4] st[5]
PRINT st[4]

# Final HALT
HALT
